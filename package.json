{
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind.input.css -o ./assets/tailwind.css --minify",
    "watch:tailwind": "npx tailwindcss -i ./tailwind.input.css -o ./assets/tailwind.css --watch",
    "shopify:dev": "shopify theme dev",
    "dev": "npm-run-all --parallel watch:tailwind shopify:dev"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.2"
  }
}
