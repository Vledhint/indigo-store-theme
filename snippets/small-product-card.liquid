{% doc %}
  Renders a product card with image, add-to-cart and buy buttons, title, price, and color swatches.

  @param {product} product - The product to render

  @example
  {% render 'small-product-card', product: product %}
{% enddoc %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign color_option_index = nil
  for option in product.options
    if option == 'Color' or option == 'color' or option == 'Colour' or option == 'colour' or option == 'COLOR'
      assign color_option_index = forloop.index0
    endif
  endfor
-%}

<div class="flex flex-col">
  <a href="{{ product.url }}" class="group block overflow-hidden aspect-auto" aria-label="{{ product.title | escape }}">
    {%- if product.featured_image -%}
      {{ product.featured_image | image_url: width: 250, height: 250, crop: 'center' | image_tag: loading: 'lazy', width: 250, height: 250, class: 'w-[250px] h-[250px] object-cover transition-transform duration-500 group-hover:scale-[1.04] mx-auto' }}
    {%- else -%}
      {{ 'product' | placeholder_svg_tag: 'w-full h-full object-cover' }}
    {%- endif -%}
  </a>

  <div class="flex mt-2">
    <form action="{{ routes.cart_add_url }}" method="post" class="flex flex-1">
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <button type="submit" class="flex-1 py-1 px-1 text-[16px] uppercase tracking-wide border-[1.5px] border-[#1F3D7C] border-r-0 bg-[#1F3D7C] text-white cursor-pointer transition-colors hover:bg-[#1F3D7C] hover:text-white font-[inherit] mr-3 rounded-s-full">
        {{- 'products.add_to_cart_icon' | t -}}
      </button>
    </form>
    <a href="{{ product.url }}" class="flex-1 flex items-center justify-center py-2 px-1 text-[16px] uppercase tracking-wide border-[1.5px] border-[#1F3D7C] bg-[#1F3D7C] text-white no-underline transition-colors ml-3 rounded-r-full">
      {{- 'products.buy_now_icon' | t -}}
    </a>
  </div>

  <div class="mt-2">
    <p class="text-[11px] font-bold uppercase tracking-[0.04em] leading-tight mb-1">{{ product.title | escape }}</p>
    <p class="text-xs font-semibold text-gray-500">{{ product.price | money }}</p>
    {%- if color_option_index -%}
      <div class="flex gap-1 mt-1.5 flex-wrap">
        {%- assign seen = '' -%}
        {%- for variant in product.variants -%}
          {%- if color_option_index == 0 -%}{%- assign cv = variant.option1 -%}
          {%- elsif color_option_index == 1 -%}{%- assign cv = variant.option2 -%}
          {%- else -%}{%- assign cv = variant.option3 -%}
          {%- endif -%}
          {%- assign cv_key = '|' | append: cv | append: '|' -%}
          {%- unless seen contains cv_key -%}
            {%- assign seen = seen | append: cv_key -%}
            <span class="w-3 h-3 rounded-full border border-black/20 inline-block shrink-0" title="{{ cv | escape }}" style="background:{{ cv | downcase | replace: ' ', '' }}"></span>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>
