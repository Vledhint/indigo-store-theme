{% doc %}
  Renders a product card with image, add-to-cart and buy buttons, title, price, and color swatches.

  @param {product} product - The product to render

  @example
  {% render 'product-card', product: product %}
{% enddoc %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign color_option_index = nil
  for option in product.options
    if option == 'Color' or option == 'color' or option == 'Colour' or option == 'colour' or option == 'COLOR'
      assign color_option_index = forloop.index0
    endif
  endfor
-%}

<div class="product-card">
  <a href="{{ product.url }}" class="product-card__media" aria-label="{{ product.title | escape }}">
    {%- if product.featured_image -%}
      {{ product.featured_image | image_url: width: 600, height: 720, crop: 'center' | image_tag: loading: 'lazy', width: 600, height: 720 }}
    {%- else -%}
      {{ 'product' | placeholder_svg_tag: 'product-card__placeholder' }}
    {%- endif -%}
  </a>

  <div class="product-card__actions">
    <form action="{{ routes.cart_add_url }}" method="post" class="product-card__form">
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <button type="submit" class="pc-btn pc-btn--outline">{{ 'products.add_to_cart' | t }}</button>
    </form>
    <a href="{{ product.url }}" class="pc-btn pc-btn--primary">{{ 'products.buy_now' | t }}</a>
  </div>

  <div class="product-card__info">
    <p class="product-card__title">{{ product.title | escape }}</p>
    <p class="product-card__price">{{ product.price | money }}</p>
    {%- if color_option_index -%}
      <div class="product-card__swatches">
        {%- assign seen = '' -%}
        {%- for variant in product.variants -%}
          {%- if color_option_index == 0 -%}{%- assign cv = variant.option1 -%}
          {%- elsif color_option_index == 1 -%}{%- assign cv = variant.option2 -%}
          {%- else -%}{%- assign cv = variant.option3 -%}
          {%- endif -%}
          {%- assign cv_key = '|' | append: cv | append: '|' -%}
          {%- unless seen contains cv_key -%}
            {%- assign seen = seen | append: cv_key -%}
            <span class="product-card__swatch" title="{{ cv | escape }}" style="background:{{ cv | downcase | replace: ' ', '' }}"></span>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .product-card {
    display: flex;
    flex-direction: column;
  }
  .product-card__media {
    display: block;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #f0f0f0;
    text-decoration: none;
  }
  .product-card__media img,
  .product-card__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }
  .product-card__media:hover img {
    transform: scale(1.04);
  }
  .product-card__actions {
    display: flex;
    margin-top: 0.5rem;
    gap: 0;
  }
  .product-card__form {
    flex: 1;
    display: flex;
  }
  .product-card__form .pc-btn {
    flex: 1;
    border-right: none;
  }
  .pc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 0.5rem 0.5rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    border: 1.5px solid #1F3D7C;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
    font-family: inherit;
  }
  .pc-btn--primary {
    background: #1F3D7C;
    color: #fff;
    flex: 1;
  }
  .pc-btn--primary:hover {
    background: #162d5c;
    border-color: #162d5c;
  }
  .pc-btn--outline {
    background: #fff;
    color: #1F3D7C;
  }
  .pc-btn--outline:hover {
    background: #1F3D7C;
    color: #fff;
  }
  .product-card__info {
    margin-top: 0.5rem;
  }
  .product-card__title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.3;
    margin: 0 0 0.2rem;
  }
  .product-card__price {
    font-size: 0.75rem;
    font-weight: 600;
    color: #444;
    margin: 0;
  }
  .product-card__swatches {
    display: flex;
    gap: 4px;
    margin-top: 6px;
    flex-wrap: wrap;
  }
  .product-card__swatch {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.2);
    display: inline-block;
    flex-shrink: 0;
  }
{% endstylesheet %}
