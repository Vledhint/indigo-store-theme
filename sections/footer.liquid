<footer class="bg-black text-white py-12 px-8 mt-auto">
  <div class="grid grid-cols-3 sm:grid-cols-1 gap-8 max-w-[960px] mx-auto">
    <div class="flex flex-col gap-2.5">
      <h3 class="text-[10px] font-extrabold uppercase tracking-[0.1em] text-white mb-1">{{ section.settings.col1_title }}</h3>
      {%- for link in section.settings.col1_menu.links -%}
        <a href="{{ link.url }}" class="text-[11px] font-bold uppercase tracking-wide text-gray-400 no-underline hover:text-white transition-colors leading-relaxed">{{ link.title }}</a>
      {%- endfor -%}
    </div>
    <div class="flex flex-col gap-2.5">
      <h3 class="text-[10px] font-extrabold uppercase tracking-[0.1em] text-white mb-1">{{ section.settings.col2_title }}</h3>
      {%- for link in section.settings.col2_menu.links -%}
        <a href="{{ link.url }}" class="text-[11px] font-bold uppercase tracking-wide text-gray-400 no-underline hover:text-white transition-colors leading-relaxed">{{ link.title }}</a>
      {%- endfor -%}
    </div>
    <div class="flex flex-col gap-2.5">
      <h3 class="text-[10px] font-extrabold uppercase tracking-[0.1em] text-white mb-1">{{ section.settings.col3_title }}</h3>
      {%- for link in section.settings.col3_menu.links -%}
        <a href="{{ link.url }}" class="text-[11px] font-bold uppercase tracking-wide text-gray-400 no-underline hover:text-white transition-colors leading-relaxed">{{ link.title }}</a>
      {%- endfor -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "text",
      "id": "col1_title",
      "label": "Column 1 title",
      "default": "Términos y condiciones"
    },
    {
      "type": "link_list",
      "id": "col1_menu",
      "label": "Column 1 links"
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "text",
      "id": "col2_title",
      "label": "Column 2 title",
      "default": "Información"
    },
    {
      "type": "link_list",
      "id": "col2_menu",
      "label": "Column 2 links"
    },
    {
      "type": "header",
      "content": "Column 3"
    },
    {
      "type": "text",
      "id": "col3_title",
      "label": "Column 3 title",
      "default": "Políticas"
    },
    {
      "type": "link_list",
      "id": "col3_menu",
      "label": "Column 3 links"
    }
  ]
}
{% endschema %}
