<footer class="site-footer">
  <div class="footer__inner">
    <div class="footer__col">
      <h3 class="footer__col-title">{{ section.settings.col1_title }}</h3>
      {%- for link in section.settings.col1_menu.links -%}
        <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
      {%- endfor -%}
    </div>
    <div class="footer__col">
      <h3 class="footer__col-title">{{ section.settings.col2_title }}</h3>
      {%- for link in section.settings.col2_menu.links -%}
        <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
      {%- endfor -%}
    </div>
    <div class="footer__col">
      <h3 class="footer__col-title">{{ section.settings.col3_title }}</h3>
      {%- for link in section.settings.col3_menu.links -%}
        <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
      {%- endfor -%}
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    background: #000;
    color: #fff;
    padding: 3rem 2rem;
    margin-top: auto;
  }
  .footer__inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .footer__col-title {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin: 0 0 0.25rem;
  }
  .footer__link {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #aaa;
    text-decoration: none;
    transition: color 0.2s;
    line-height: 1.6;
  }
  .footer__link:hover {
    color: #fff;
  }
  @media (max-width: 640px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "text",
      "id": "col1_title",
      "label": "Column 1 title",
      "default": "Términos y condiciones"
    },
    {
      "type": "link_list",
      "id": "col1_menu",
      "label": "Column 1 links"
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "text",
      "id": "col2_title",
      "label": "Column 2 title",
      "default": "Información"
    },
    {
      "type": "link_list",
      "id": "col2_menu",
      "label": "Column 2 links"
    },
    {
      "type": "header",
      "content": "Column 3"
    },
    {
      "type": "text",
      "id": "col3_title",
      "label": "Column 3 title",
      "default": "Políticas"
    },
    {
      "type": "link_list",
      "id": "col3_menu",
      "label": "Column 3 links"
    }
  ]
}
{% endschema %}
