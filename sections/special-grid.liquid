{%- comment -%}
  Gender/category landing page. Used for HOMBRE, MUJER, KIDS sections.
  Shows a full-width hero then a mosaic grid of sub-category tiles.
{%- endcomment -%}

<section class="gender-hero">
  {%- if section.settings.hero_image -%}
    {{ section.settings.hero_image | image_url: width: 1600 | image_tag: loading: 'eager', class: 'gender-hero__img', width: 1600, height: 700 }}
  {%- else -%}
    <div class="gender-hero__placeholder">{{ 'lifestyle-2' | placeholder_svg_tag }}</div>
  {%- endif -%}
  <div class="gender-hero__overlay">
    <h1 class="gender-hero__title">{{ section.settings.hero_title }}</h1>
  </div>
</section>

{%- if section.blocks.size > 0 -%}
  <div class="category-grid">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link }}"
        class="category-tile category-tile--{{ block.settings.size }}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image -%}
          {{ block.settings.image | image_url: width: 800, height: 960, crop: 'center' | image_tag: loading: 'lazy', width: 800, height: 960, class: 'category-tile__img' }}
        {%- else -%}
          <div class="category-tile__placeholder">{{ 'collection-1' | placeholder_svg_tag }}</div>
        {%- endif -%}
        <div class="category-tile__overlay">
          <span class="category-tile__label">{{ block.settings.label }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
{%- endif -%}

{% stylesheet %}
  /* Hero */
  .gender-hero {
    position: relative;
    overflow: hidden;
    width: 100%;
  }
  .gender-hero__img {
    width: 100%;
    height: auto;
    max-height: 70vh;
    object-fit: cover;
    display: block;
  }
  .gender-hero__placeholder {
    width: 100%;
    aspect-ratio: 16/7;
    background: #ccc;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gender-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 2.5rem 3rem;
    background: linear-gradient(to top, rgba(0,0,0,0.45) 30%, transparent 70%);
  }
  .gender-hero__title {
    color: #fff;
    font-size: clamp(3rem, 10vw, 8rem);
    font-weight: 900;
    font-style: italic;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 16px rgba(0,0,0,0.3);
  }

  /* Category mosaic grid */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 300px;
    gap: 2px;
  }
  .category-tile {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    background: #111;
  }
  .category-tile--wide {
    grid-column: span 2;
  }
  .category-tile--tall {
    grid-row: span 2;
  }
  .category-tile__img,
  .category-tile__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease, opacity 0.3s ease;
  }
  .category-tile__placeholder svg {
    width: 100%;
    height: 100%;
  }
  .category-tile:hover .category-tile__img {
    transform: scale(1.06);
    opacity: 0.85;
  }
  .category-tile__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 30%, transparent 70%);
  }
  .category-tile__label {
    color: #fff;
    font-size: clamp(1rem, 3vw, 1.75rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-style: italic;
    line-height: 1;
  }
  @media (max-width: 768px) {
    .category-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
    }
    .category-tile--wide {
      grid-column: span 2;
    }
    .category-tile--tall {
      grid-row: span 1;
    }
    .gender-hero__overlay {
      padding: 1.5rem;
    }
  }
  @media (max-width: 480px) {
    .category-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }
    .category-tile--wide {
      grid-column: span 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.indigo_grid",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "HOMBRE"
    }
  ],
  "blocks": [
    {
      "type": "category_tile",
      "name": "Category tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "JEANS"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Tile size",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "wide", "label": "Wide (spans 2 columns)" },
            { "value": "tall", "label": "Tall (spans 2 rows)" }
          ],
          "default": "normal"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.collections_grid",
      "blocks": [
        { "type": "category_tile", "settings": { "label": "JEANS", "size": "tall" } },
        { "type": "category_tile", "settings": { "label": "CHAMARRAS", "size": "normal" } },
        { "type": "category_tile", "settings": { "label": "PLAYERAS", "size": "normal" } },
        { "type": "category_tile", "settings": { "label": "SUDADERAS", "size": "normal" } },
        { "type": "category_tile", "settings": { "label": "CAMISAS", "size": "wide" } },
        { "type": "category_tile", "settings": { "label": "BERMUDAS", "size": "normal" } },
        { "type": "category_tile", "settings": { "label": "LIQUIDACIÓN", "size": "normal" } },
        { "type": "category_tile", "settings": { "label": "EDICIÓN LIMITADA", "size": "normal" } }
      ]
    }
  ]
}
{% endschema %}
