<div class="product-page">
  {%- comment -%} Left: image gallery 2×2 {%- endcomment -%}
  <div class="product-gallery">
    {%- assign images = product.images -%}
    {%- for image in images limit: 4 -%}
      <div class="product-gallery__item">
        {{ image | image_url: width: 800, height: 960, crop: 'center' | image_tag: loading: 'eager', width: 800, height: 960, class: 'product-gallery__img' }}
      </div>
    {%- else -%}
      <div class="product-gallery__item product-gallery__item--placeholder">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%} Right: product info + form {%- endcomment -%}
  <div class="product-info">
    <p class="product-info__vendor">{{ product.vendor | upcase }}</p>
    <h1 class="product-info__title">{{ product.title | upcase }}</h1>

    <div class="product-info__price">
      <span class="product-info__price-amount">{{ product.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="product-info__price-compare">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    {%- assign color_option = nil -%}
    {%- for option in product.options -%}
      {%- if option == 'Color' or option == 'color' or option == 'Colour' -%}
        {%- assign color_option = option -%}
        {%- assign color_option_pos = forloop.index -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if color_option -%}
      <div class="product-info__colors">
        {%- assign seen = '' -%}
        {%- for variant in product.variants -%}
          {%- if color_option_pos == 1 -%}{%- assign cv = variant.option1 -%}
          {%- elsif color_option_pos == 2 -%}{%- assign cv = variant.option2 -%}
          {%- else -%}{%- assign cv = variant.option3 -%}
          {%- endif -%}
          {%- assign cv_key = '|' | append: cv | append: '|' -%}
          {%- unless seen contains cv_key -%}
            {%- assign seen = seen | append: cv_key -%}
            <button
              type="button"
              class="color-swatch"
              title="{{ cv | escape }}"
              style="background: {{ cv | downcase | replace: ' ', '' }}"
              data-color="{{ cv | escape }}"
              aria-label="{{ cv | escape }}"
            ></button>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- form 'product', product -%}
      {%- assign current_variant = product.selected_or_first_available_variant -%}

      {%- assign size_option = nil -%}
      {%- for option in product.options -%}
        {%- if option == 'Size' or option == 'size' or option == 'Talla' or option == 'talla' -%}
          {%- assign size_option = option -%}
          {%- assign size_pos = forloop.index -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if size_option -%}
        <div class="product-form__sizes">
          <select name="id" id="product-variant-{{ section.id }}" class="product-form__size-select" aria-label="{{ 'products.size' | t }}">
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}"
                {%- if variant == current_variant %} selected{% endif %}
                {%- unless variant.available %} disabled{% endunless %}>
                {%- if size_pos == 1 -%}{{ variant.option1 }}
                {%- elsif size_pos == 2 -%}{{ variant.option2 }}
                {%- else -%}{{ variant.option3 }}{%- endif -%}
                {%- unless variant.available %} – {{ 'products.sold_out' | t }}{%- endunless -%}
              </option>
            {%- endfor -%}
          </select>
          <svg class="product-form__size-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      {%- else -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
      {%- endif -%}

      <a href="#" class="product-form__size-guide">{{ 'products.size_guide' | t }}</a>

      <div class="product-form__actions">
        <button type="submit" name="add" class="product-form__btn product-form__btn--cart">
          {{- 'products.add_to_cart' | t -}}
        </button>
        {{ form | payment_button }}
      </div>
    {%- endform -%}

    {%- if product.description != blank -%}
      <details class="product-accordion">
        <summary class="product-accordion__trigger">
          <span>{{ 'products.description' | t }}</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="product-accordion__body">{{ product.description }}</div>
      </details>
    {%- endif -%}

    <details class="product-accordion">
      <summary class="product-accordion__trigger">
        <span>{{ 'products.shipping_returns' | t }}</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="product-accordion__body">{{ section.settings.shipping_text }}</div>
    </details>

    <details class="product-accordion">
      <summary class="product-accordion__trigger">
        <span>{{ 'products.care' | t }}</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="product-accordion__body">{{ section.settings.care_text }}</div>
    </details>

    <details class="product-accordion">
      <summary class="product-accordion__trigger">
        <span>{{ 'products.legals' | t }}</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="product-accordion__body">{{ section.settings.legal_text }}</div>
    </details>
  </div>
</div>

{% stylesheet %}
  .product-page {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 0;
    min-height: 80vh;
  }
  /* Gallery */
  .product-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    background: #e8e8e8;
    align-self: start;
  }
  .product-gallery__item {
    overflow: hidden;
    aspect-ratio: 5/6;
    background: #f0f0f0;
  }
  .product-gallery__item--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .product-gallery__item:hover .product-gallery__img {
    transform: scale(1.03);
  }
  /* Info panel */
  .product-info {
    padding: 2rem 2rem 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 5rem;
    align-self: start;
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
  }
  .product-info__vendor {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #888;
    margin: 0;
  }
  .product-info__title {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    line-height: 1.3;
    margin: 0;
  }
  .product-info__price {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .product-info__price-amount {
    font-size: 1.125rem;
    font-weight: 700;
    color: #111;
  }
  .product-info__price-compare {
    font-size: 0.875rem;
    color: #999;
    text-decoration: line-through;
  }
  /* Color swatches */
  .product-info__colors {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .color-swatch {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.15s;
    padding: 0;
    outline: 1px solid rgba(0,0,0,0.15);
    outline-offset: 0;
  }
  .color-swatch:hover,
  .color-swatch.is-active {
    outline-color: #1F3D7C;
    outline-width: 2px;
    outline-offset: 2px;
  }
  /* Size selector */
  .product-form__sizes {
    position: relative;
  }
  .product-form__size-select {
    width: 100%;
    appearance: none;
    background: #1F3D7C;
    color: #fff;
    border: none;
    padding: 0.875rem 2.5rem 0.875rem 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    font-family: inherit;
  }
  .product-form__size-chevron {
    position: absolute;
    right: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1rem;
    height: 1rem;
    pointer-events: none;
    color: #fff;
  }
  .product-form__size-guide {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #666;
    text-decoration: underline;
    text-underline-offset: 2px;
    align-self: center;
  }
  /* Form actions */
  .product-form__actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .product-form__btn {
    width: 100%;
    padding: 0.875rem 1rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 2px solid #1F3D7C;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, color 0.15s;
  }
  .product-form__btn--cart {
    background: #fff;
    color: #1F3D7C;
  }
  .product-form__btn--cart:hover {
    background: #f0f0f0;
  }
  /* Shopify payment button override */
  .product-form__actions .shopify-payment-button__button {
    border-radius: 0 !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
  }
  /* Accordion */
  .product-accordion {
    border-top: 1px solid #e0e0e0;
  }
  .product-accordion:last-child {
    border-bottom: 1px solid #e0e0e0;
  }
  .product-accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 0;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .product-accordion__trigger::-webkit-details-marker {
    display: none;
  }
  .product-accordion__trigger svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  details[open] .product-accordion__trigger svg {
    transform: rotate(180deg);
  }
  .product-accordion__body {
    padding: 0 0 1rem;
    font-size: 0.8rem;
    color: #555;
    line-height: 1.6;
  }
  @media (max-width: 1024px) {
    .product-page {
      grid-template-columns: 1fr;
    }
    .product-info {
      position: static;
      max-height: none;
      padding: 1.5rem;
    }
  }
  @media (max-width: 768px) {
    .product-gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "textarea",
      "id": "shipping_text",
      "label": "Shipping & returns text",
      "default": "Free shipping on orders over $500. Returns accepted within 30 days."
    },
    {
      "type": "textarea",
      "id": "care_text",
      "label": "Care instructions",
      "default": "Machine wash cold. Do not bleach. Tumble dry low."
    },
    {
      "type": "textarea",
      "id": "legal_text",
      "label": "Legal information",
      "default": "All sales subject to our terms and conditions."
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
