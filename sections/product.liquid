<div class="grid grid-cols-[1fr_420px] lg:grid-cols-1 min-h-[80vh]">

  {%- comment -%} Left: 2×2 image gallery {%- endcomment -%}
  <div class="grid grid-cols-2 gap-px bg-gray-200 self-start">
    {%- for image in product.images limit: 4 -%}
      <div class="group overflow-hidden aspect-[5/6] bg-gray-100">
        {{ image | image_url: width: 800, height: 960, crop: 'center' | image_tag: loading: 'eager', width: 800, height: 960, class: 'w-full h-full object-cover block transition-transform duration-500 group-hover:scale-[1.03]' }}
      </div>
    {%- else -%}
      <div class="aspect-[5/6] bg-gray-100 flex items-center justify-center">
        {{ 'product-1' | placeholder_svg_tag: 'w-full h-full' }}
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%} Right: info panel {%- endcomment -%}
  <div class="product-info-panel flex flex-col gap-4 px-10 py-8 lg:px-6 lg:py-6 sticky top-20 self-start overflow-y-auto">

    <p class="text-[10px] font-bold tracking-[0.15em] text-gray-400 m-0 uppercase">{{ product.vendor }}</p>
    <h1 class="text-base font-extrabold tracking-wide leading-tight m-0 uppercase">{{ product.title }}</h1>

    <div class="flex items-baseline gap-3">
      <span class="text-lg font-bold text-gray-900">{{ product.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="text-sm text-gray-400 line-through">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    {%- assign color_option_index = nil -%}
    {%- for option in product.options -%}
      {%- if option == 'Color' or option == 'color' or option == 'Colour' -%}
        {%- assign color_option_index = forloop.index0 -%}
        {%- assign color_option_pos = forloop.index -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if color_option_index -%}
      <div class="flex gap-2 flex-wrap">
        {%- assign seen = '' -%}
        {%- for variant in product.variants -%}
          {%- if color_option_pos == 1 -%}{%- assign cv = variant.option1 -%}
          {%- elsif color_option_pos == 2 -%}{%- assign cv = variant.option2 -%}
          {%- else -%}{%- assign cv = variant.option3 -%}
          {%- endif -%}
          {%- assign cv_key = '|' | append: cv | append: '|' -%}
          {%- unless seen contains cv_key -%}
            {%- assign seen = seen | append: cv_key -%}
            <button type="button"
              class="w-7 h-7 rounded-full border-2 border-transparent p-0 cursor-pointer outline outline-1 outline-black/20 outline-offset-0 hover:outline-[#1F3D7C] hover:outline-2 hover:outline-offset-2 transition-all"
              title="{{ cv | escape }}"
              style="background:{{ cv | downcase | replace: ' ', '' }}"
              aria-label="{{ cv | escape }}"
            ></button>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- form 'product', product -%}
      {%- assign current_variant = product.selected_or_first_available_variant -%}
      {%- assign size_pos = nil -%}
      {%- for option in product.options -%}
        {%- if option == 'Size' or option == 'size' or option == 'Talla' or option == 'talla' -%}
          {%- assign size_pos = forloop.index -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if size_pos -%}
        <div class="relative">
          <select name="id" class="w-full appearance-none bg-[#1F3D7C] text-white border-none py-3.5 pl-4 pr-10 text-xs font-bold uppercase tracking-[0.1em] cursor-pointer font-[inherit]" aria-label="{{ 'products.size' | t }}">
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}"
                {%- if variant == current_variant %} selected{% endif %}
                {%- unless variant.available %} disabled{% endunless %}>
                {%- if size_pos == 1 -%}{{ variant.option1 }}
                {%- elsif size_pos == 2 -%}{{ variant.option2 }}
                {%- else -%}{{ variant.option3 }}{%- endif -%}
                {%- unless variant.available %} – {{ 'products.sold_out' | t }}{%- endunless -%}
              </option>
            {%- endfor -%}
          </select>
          <svg class="absolute right-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-white pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      {%- else -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
      {%- endif -%}

      <a href="#" class="self-center text-[11px] font-semibold uppercase tracking-wide text-gray-500 underline underline-offset-2 hover:text-gray-800 transition-colors">
        {{- 'products.size_guide' | t -}}
      </a>

      <div class="flex flex-col gap-2">
        <button type="submit" name="add" class="w-full py-3.5 text-xs font-extrabold uppercase tracking-[0.12em] border-2 border-[#1F3D7C] bg-white text-[#1F3D7C] cursor-pointer font-[inherit] hover:bg-gray-50 transition-colors">
          {{- 'products.add_to_cart' | t -}}
        </button>
        {{ form | payment_button }}
      </div>
    {%- endform -%}

    {%- if product.description != blank -%}
      <details class="border-t border-gray-200 product-accordion">
        <summary class="flex items-center justify-between py-3.5 text-[11px] font-bold uppercase tracking-[0.1em] cursor-pointer select-none list-none">
          <span>{{ 'products.description' | t }}</span>
          <svg class="w-4 h-4 shrink-0 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="pb-4 text-sm text-gray-600 leading-relaxed">{{ product.description }}</div>
      </details>
    {%- endif -%}

    {%- assign accordions = 'products.shipping_returns,products.care,products.legals' | split: ',' -%}
    {%- assign accordion_texts = section.settings.shipping_text | append: '||' | append: section.settings.care_text | append: '||' | append: section.settings.legal_text | split: '||' -%}

    {%- for label in accordions -%}
      <details class="border-t border-gray-200 product-accordion{% if forloop.last %} border-b{% endif %}">
        <summary class="flex items-center justify-between py-3.5 text-[11px] font-bold uppercase tracking-[0.1em] cursor-pointer select-none list-none">
          <span>{{ label | t }}</span>
          <svg class="w-4 h-4 shrink-0 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="pb-4 text-sm text-gray-600 leading-relaxed">{{ accordion_texts[forloop.index0] }}</div>
      </details>
    {%- endfor -%}

  </div>
</div>

{% stylesheet %}
  .product-info-panel {
    max-height: calc(100vh - 5rem);
  }
  @media (max-width: 1024px) {
    .product-info-panel {
      position: static;
      max-height: none;
    }
  }
  details.product-accordion summary::-webkit-details-marker { display: none; }
  details[open].product-accordion > summary svg { transform: rotate(180deg); }
  .shopify-payment-button__button {
    border-radius: 0 !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.12em !important;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "textarea",
      "id": "shipping_text",
      "label": "Shipping & returns text",
      "default": "Free shipping on orders over $500. Returns accepted within 30 days."
    },
    {
      "type": "textarea",
      "id": "care_text",
      "label": "Care instructions",
      "default": "Machine wash cold. Do not bleach. Tumble dry low."
    },
    {
      "type": "textarea",
      "id": "legal_text",
      "label": "Legal information",
      "default": "All sales subject to our terms and conditions."
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
