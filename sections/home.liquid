{%- comment -%} ── Hero ── {%- endcomment -%}
<section class="relative w-full overflow-hidden">
  {%- if section.settings.hero_image -%}
    {{ section.settings.hero_image | image_url: width: 2000 | image_tag: loading: 'eager', class: 'w-full h-auto block max-h-[90vh] object-cover', width: 2000, height: 900 }}
  {%- else -%}
    <div class="w-full aspect-[16/7] bg-gray-300 flex items-center justify-center">
      {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full' }}
    </div>
  {%- endif -%}
  <div class="absolute inset-0 flex items-center justify-center bg-black/10">
    <h1 class="text-white font-black uppercase italic text-center leading-none tracking-tight text-[clamp(3rem,10vw,9rem)] [text-shadow:0_2px_20px_rgba(0,0,0,0.4)]">
      {{ section.settings.hero_text }}
    </h1>
  </div>
</section>

{%- comment -%} ── Features bar ── {%- endcomment -%}
<section class="bg-[#1F3D7C] py-6 px-8">
  <div class="grid grid-cols-4 sm:grid-cols-2 gap-4 max-w-[960px] mx-auto">
    <div class="flex flex-col items-center text-center text-white gap-1">
      <span class="text-[10px] font-bold uppercase tracking-[0.15em] opacity-80">{{ section.settings.feature_1_label }}</span>
      <span class="text-sm font-extrabold uppercase tracking-wide">{{ section.settings.feature_1_text }}</span>
    </div>
    <div class="flex flex-col items-center text-center text-white gap-1">
      <span class="text-[10px] font-bold uppercase tracking-[0.15em] opacity-80">{{ section.settings.feature_2_label }}</span>
      <span class="text-sm font-extrabold uppercase tracking-wide">{{ section.settings.feature_2_text }}</span>
    </div>
    <div class="flex flex-col items-center text-center text-white gap-1">
      <span class="text-[10px] font-bold uppercase tracking-[0.15em] opacity-80">{{ section.settings.feature_3_label }}</span>
      <span class="text-sm font-extrabold uppercase tracking-wide">{{ section.settings.feature_3_text }}</span>
    </div>
    <div class="flex flex-col items-center text-center text-white gap-1">
      <span class="text-[10px] font-bold uppercase tracking-[0.15em] opacity-80">{{ section.settings.feature_4_label }}</span>
      <span class="text-sm font-extrabold uppercase tracking-wide">{{ section.settings.feature_4_text }}</span>
    </div>
  </div>
</section>

{%- comment -%} ── Men's section ── {%- endcomment -%}
{%- unless section.settings.men_collection == blank -%}
  {%- render 'ticker', text: section.settings.men_ticker_text, theme: 'dark' -%}
  <section class="px-8 py-8 sm:px-4 sm:py-5">
    <div class="grid grid-cols-4 lg:grid-cols-3 sm:grid-cols-2 gap-5 sm:gap-3 max-w-[1200px] mx-auto">
      {%- for product in section.settings.men_collection.products limit: 4 -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>
  </section>
{%- endunless -%}

{%- comment -%} ── Tagline ── {%- endcomment -%}
<section class="relative overflow-hidden">
  {%- if section.settings.tagline_image -%}
    {{ section.settings.tagline_image | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'w-full h-auto max-h-[500px] object-cover block', width: 1600, height: 700 }}
  {%- else -%}
    <div class="w-full aspect-[16/7] bg-gray-400"></div>
  {%- endif -%}
  <div class="absolute inset-0 flex items-center justify-center bg-black/35 px-8">
    <p class="text-white font-black italic text-center leading-tight max-w-[900px] text-[clamp(1.5rem,4vw,3.5rem)]">
      {{ section.settings.tagline_text }}
    </p>
  </div>
</section>

{%- comment -%} ── Women's section ── {%- endcomment -%}
{%- unless section.settings.women_collection == blank -%}
  {%- render 'ticker', text: section.settings.women_ticker_text, theme: 'dark' -%}
  <section class="px-8 py-8 sm:px-4 sm:py-5">
    <div class="grid grid-cols-4 lg:grid-cols-3 sm:grid-cols-2 gap-5 sm:gap-3 max-w-[1200px] mx-auto">
      {%- for product in section.settings.women_collection.products limit: 4 -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>
  </section>
{%- endunless -%}

{%- comment -%} ── Kids' section ── {%- endcomment -%}
{%- unless section.settings.kids_collection == blank -%}
  {%- render 'ticker', text: section.settings.kids_ticker_text, theme: 'dark' -%}
  <section class="px-8 py-8 sm:px-4 sm:py-5">
    <div class="grid grid-cols-4 lg:grid-cols-3 sm:grid-cols-2 gap-5 sm:gap-3 max-w-[1200px] mx-auto">
      {%- for product in section.settings.kids_collection.products limit: 4 -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>
  </section>
{%- endunless -%}

{%- comment -%} ── Sale / Rebajas ── {%- endcomment -%}
{%- unless section.settings.sale_collection == blank -%}
  <section class="bg-[#1F3D7C] grid grid-cols-2 sm:grid-cols-1 min-h-[480px]">
    <div class="flex flex-col items-start justify-center p-12 md:p-8 sm:p-6 gap-6">
      <h2 class="font-black italic uppercase text-white leading-none tracking-tight text-[clamp(4rem,10vw,8rem)]">
        {{ section.settings.sale_title }}
      </h2>
      <a href="{{ section.settings.sale_collection.url }}" class="inline-flex items-center justify-center px-8 py-3 bg-white text-[#1F3D7C] text-xs font-extrabold uppercase tracking-[0.12em] no-underline hover:bg-gray-100 transition-colors">
        {{- 'sections.home.sale_cta' | t -}}
      </a>
    </div>
    <div class="grid grid-cols-2">
      {%- for product in section.settings.sale_collection.products limit: 4 -%}
        <a href="{{ product.url }}" class="group block overflow-hidden aspect-square">
          {%- if product.featured_image -%}
            {{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' | image_tag: loading: 'lazy', width: 400, height: 400, class: 'w-full h-full object-cover block transition-transform duration-500 group-hover:scale-[1.04]' }}
          {%- else -%}
            {{ 'product' | placeholder_svg_tag: 'w-full h-full object-cover' }}
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </section>
{%- endunless -%}

