{%- render 'ticker', text: collection.title, theme: 'dark' -%}

<div class="flex items-center gap-2 px-8 py-4 border-b border-gray-200 text-xs font-bold uppercase tracking-[0.08em] cursor-pointer sm:px-4">
  <span>{{ 'collections.filters' | t }}</span>
  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
</div>

<div class="px-8 pt-6 pb-12 max-w-[1300px] mx-auto sm:px-4">
  {%- paginate collection.products by 12 -%}
    <div class="grid grid-cols-4 lg:grid-cols-3 md:grid-cols-2 gap-5 sm:gap-3">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        <p class="col-span-4 text-center py-12 text-sm text-gray-500">{{ 'collections.empty' | t }}</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="collection-pagination flex justify-center gap-2 mt-12 pt-8 border-t border-gray-200">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% stylesheet %}
  .collection-pagination a,
  .collection-pagination span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    padding: 0 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-decoration: none;
    border: 1.5px solid #1F3D7C;
    color: #1F3D7C;
    transition: background 0.15s, color 0.15s;
  }
  .collection-pagination .current,
  .collection-pagination a:hover {
    background: #1F3D7C;
    color: #fff;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": []
}
{% endschema %}
